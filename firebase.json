{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "functions/**"],
    "rewrites": [
      { "source": "/api/afip/**", "function": "afip" }
    ]
  }
}
